# ============================================================
#  SatuBooster Telephony Server — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.

# ─── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── API Authentication ───────────────────────────────────────
# A long random string used by the CRM to authenticate with us.
# Generate with: openssl rand -hex 32
API_KEY=your-very-secure-api-key-here

# ─── Asterisk AMI (Manager Interface) ────────────────────────
# These must match /etc/asterisk/manager.conf on your FreePBX server
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USERNAME=crm_user
AMI_SECRET=your-ami-secret-here

# ─── Asterisk ARI (REST Interface) ───────────────────────────
# These must match /etc/asterisk/ari.conf on your FreePBX server
ARI_HOST=http://127.0.0.1
ARI_PORT=8088
ARI_USERNAME=satubooster_api
ARI_PASSWORD=your-ari-password-here

# ─── Asterisk Call Context ────────────────────────────────────
# The dialplan context used for outbound calls
ASTERISK_CONTEXT=from-internal
# Default exten priority
ASTERISK_PRIORITY=1

# ─── Supabase (for uploading recordings + forwarding webhooks) ─
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_WEBHOOK_URL=https://your-project.supabase.co/functions/v1/telephony-webhook

# ─── Call Recordings ─────────────────────────────────────────
# Local path where Asterisk saves recordings
ASTERISK_RECORDINGS_PATH=/var/spool/asterisk/monitor
# Supabase Storage bucket name for recordings
RECORDINGS_BUCKET=call-recordings

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
# Log file directory (relative to project root)
LOG_DIR=logs

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins (CRM frontend URLs)
# Use * only in development!
CORS_ORIGINS=https://your-crm-app.vercel.app,https://your-crm.supabase.co

# ─── Docker / Deployment ─────────────────────────────────────
# FreePBX database password (used by docker-compose)
FREEPBX_DB_PASSWORD=your-secure-db-password
# Delete local recording files after uploading to Supabase? (saves disk)
DELETE_LOCAL_RECORDINGS=false
# Timezone
TZ=Asia/Kolkata
